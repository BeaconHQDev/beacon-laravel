{
  "name": "beaconhq/beacon-laravel",
  "description": "Beacon Laravel SDK — error tracking for Laravel applications",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "beaconhq/beacon-php": "^1.0",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "BeaconHQ\\Laravel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": ["BeaconHQ\\Laravel\\BeaconServiceProvider"],
      "aliases": {"Beacon": "BeaconHQ\\Laravel\\Facades\\Beacon"}
    }
  }
}
